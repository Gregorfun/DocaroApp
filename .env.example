# Docaro Umgebungsvariablen
# Kopieren Sie diese Datei zu .env und passen Sie die Werte an

# ===== Sicherheit =====
# Generieren Sie einen zufälligen Secret Key für Sessions
# Beispiel: python -c "import secrets; print(secrets.token_hex(32))"
DOCARO_SECRET_KEY=

# ===== Debug-Modus =====
# 0 = Produktionsmodus, 1 = Debug-Modus (niemals in Produktion verwenden!)
DOCARO_DEBUG=0
DOCARO_DEBUG_EXTRACT=0

# ===== OCR-Einstellungen =====
# Timeouts in Sekunden für verschiedene OCR-Operationen
DOCARO_OCR_TIMEOUT=8
DOCARO_PDF_CONVERT_TIMEOUT=15
DOCARO_ROTATION_OCR_TIMEOUT=4
DOCARO_DATE_CROP_TIMEOUT=3

# Anzahl der PDF-Seiten, die für OCR gescannt werden sollen
DOCARO_OCR_PAGES=2

# ===== Externe Tools =====
# Pfade zu Tesseract und Poppler (optional, wenn nicht im PATH)
# Windows Beispiel:
# DOCARO_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# DOCARO_POPPLER_BIN=C:\Program Files\poppler\bin
# Linux/macOS: Normalerweise nicht nötig, wenn im PATH
DOCARO_TESSERACT_CMD=
DOCARO_POPPLER_BIN=

# ===== PaddleOCR (Optional) =====
# Experimental: Verwenden Sie PaddleOCR als Fallback
# 0 = deaktiviert, 1 = aktiviert
DOCARO_USE_PADDLEOCR=0
DOCARO_PADDLEOCR_LANG=german

# ===== Tabellen-Intelligence (Optional) =====
# Ergänzt die Extraktion um Tabellenkontext (z.B. Positionen aus Rechnungen/Lieferscheinen)
DOCARO_TABLE_INTELLIGENCE_ENABLED=1
DOCARO_TABLE_INTELLIGENCE_MAX_PAGES=2

# Optionaler Webhook (z.B. eigener HF-Space-Service), sonst lokaler pdfplumber-Fallback
DOCARO_HF_TABLE_WEBHOOK=
DOCARO_HF_TABLE_TIMEOUT_SECONDS=6

# ===== LLM-Assist (Optional, z.B. Ollama lokal) =====
# Nur als Fallback bei unsicheren Ergebnissen gedacht.
DOCARO_LLM_ASSIST_ENABLED=0
DOCARO_LLM_ASSIST_MODEL=llama3.1:8b-instruct
DOCARO_LLM_ASSIST_ENDPOINT=http://127.0.0.1:11434
DOCARO_LLM_ASSIST_TIMEOUT_SECONDS=12

# ===== Logging =====
# Anzahl der Tage, für die Logs aufbewahrt werden
DOCARO_LOG_RETENTION_DAYS=30

# ===== Server-Einstellungen =====
# Host und Port für den Flask-Entwicklungsserver
DOCARO_SERVER_HOST=127.0.0.1
DOCARO_SERVER_PORT=5001

# Auto-Reload bei Code-Änderungen (nur für Entwicklung)
DOCARO_SERVER_USE_RELOADER=0

# ===== Dateisystem =====
# Tiefenscan für PDF-Dateien (langsamer, findet aber mehr Dateien)
# 0 = nur direkte Verzeichnisse, 1 = rekursive Suche
DOCARO_DEEP_SCAN=0
