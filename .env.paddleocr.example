# Docaro PaddleOCR Konfiguration
# Kopieren zu /etc/systemd/system/docaro.service Environment= Zeilen
# oder zu .env Datei wenn dotenv geladen wird

# === PaddleOCR Fallback-OCR ===
# Aktiviert PaddleOCR als intelligentes Fallback-System
DOCARO_USE_PADDLEOCR=0

# Score-Schwelle unter der PaddleOCR als Fallback aktiviert wird
# Niedrig (300): Sehr oft → bessere Genauigkeit, mehr Speicher/CPU
# Hoch (500):   Selten  → schneller, sparsamer
# Standard:     400     → guter Kompromiss
DOCARO_PADDLEOCR_FALLBACK_THRESHOLD=400

# PaddleOCR Sprache (default: "german")
# Unterstützt: "german", "ch_sim", "en", etc.
DOCARO_PADDLEOCR_LANG=german

# Ensemble-OCR für kritische Felder (Lieferantnummer, Datum)
# EXPERIMENTAL: Nutzt sowohl Tesseract als PaddleOCR und kombiniert Ergebnisse
# Kann zu besserer Genauigkeit führen, kostet aber ~2-3x länger
DOCARO_PADDLEOCR_ENSEMBLE_FIELDS=0

# === Debugging ===
# Aktiviert DEBUG-Logs für OCR-Verarbeitung
DOCARO_DEBUG_EXTRACT=0
