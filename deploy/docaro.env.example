# Docaro systemd environment
# Copy to: /etc/docaro/docaro.env

# Redis
REDIS_URL=redis://localhost:6379

# App
DOCARO_DEBUG=0
DOCARO_AUTH_REQUIRED=1
DOCARO_ALLOW_SELF_REGISTER=0
DOCARO_SESSION_COOKIE_SECURE=1
DOCARO_SESSION_IDLE_MINUTES=480
# DOCARO_LOG_FORMAT=text   # text|json

# Optional: OCR/Rendering tuning
# DOCARO_RENDER_DPI=200
# DOCARO_FOLDER_TIMEOUT=180
# DOCARO_OCR_TIMEOUT=8
# DOCARO_PDF_CONVERT_TIMEOUT=15

# Optional: Worker/diagnostics
# DOCARO_ML_CHECKS=0
# DOCARO_AUTO_PIP_INSTALL=0
# DOCARO_METRICS_ENABLED=1
# DOCARO_METRICS_PUBLIC=0
# DOCARO_METRICS_TOKEN=CHANGE_ME
# DOCARO_WORKER_METRICS_PORT=9108
# DOCARO_QUEUE_METRICS_INTERVAL_SECONDS=5
# DOCARO_QUEUE_MAX_DEPTH=200
# DOCARO_PROCESS_MAX_WORKERS=1
# DOCARO_PROCESS_QUEUE_MULTIPLIER=4
# DOCARO_PROCESS_ADAPTIVE_WORKERS=1
# DOCARO_RQ_DASHBOARD_ENABLED=0
# DOCARO_RQ_DASHBOARD_URL_PREFIX=/rq
# DOCARO_RATE_LIMIT_LOGIN=10/5m
# DOCARO_RATE_LIMIT_UPLOAD=30/5m
# DOCARO_RUNTIME_WAL_CHECKPOINT_SECONDS=600

# Optional: Sentry Error Tracking
# DOCARO_SENTRY_ENABLED=1
# DOCARO_SENTRY_DSN=https://<key>@sentry.io/<project>
# DOCARO_SENTRY_ENVIRONMENT=production
# DOCARO_RELEASE=docaro-<git-sha>
# DOCARO_SENTRY_TRACES_SAMPLE_RATE=0.1
# DOCARO_SENTRY_PROFILES_SAMPLE_RATE=0.0

# Optional: rollout / hardening
# DOCARO_CSRF_STRICT=1
# DOCARO_CSRF_CANARY_PERCENT=0
# DOCARO_UPLOAD_CANARY_PERCENT=0

# Optional: Model promotion gates
# DOCARO_MODEL_MIN_ACCURACY=0.70
# DOCARO_MODEL_MIN_F1_WEIGHTED=0.70
# DOCARO_MODEL_ALLOW_NO_EVAL=1

# Optional: Cleanup behavior
# DOCARO_PRUNE_AFTER_DOWNLOAD=1
# DOCARO_DELETE_FILES_AFTER_DOWNLOAD=0
# DOCARO_TMP_RETENTION_HOURS=24

# Optional: Seed user (NEVER commit real passwords)
# DOCARO_SEED_EMAIL=admin@docaro.local
# DOCARO_SEED_PASSWORD=CHANGE_ME
