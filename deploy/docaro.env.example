# Docaro systemd environment
# Copy to: /etc/docaro/docaro.env

# Redis
REDIS_URL=redis://localhost:6379

# App
DOCARO_DEBUG=0

# Optional: OCR/Rendering tuning
# DOCARO_RENDER_DPI=200
# DOCARO_FOLDER_TIMEOUT=180
# DOCARO_OCR_TIMEOUT=8
# DOCARO_PDF_CONVERT_TIMEOUT=15

# Optional: Worker/diagnostics
# DOCARO_ML_CHECKS=0
# DOCARO_AUTO_PIP_INSTALL=0

# Optional: Cleanup behavior
# DOCARO_PRUNE_AFTER_DOWNLOAD=1
# DOCARO_DELETE_FILES_AFTER_DOWNLOAD=0
# DOCARO_TMP_RETENTION_HOURS=24

# Optional: Seed user (NEVER commit real passwords)
# DOCARO_SEED_EMAIL=g.machuletz@bracht-autokrane.de
# DOCARO_SEED_PASSWORD=CHANGE_ME
